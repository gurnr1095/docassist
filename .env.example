# ============================================================
# DocAssist — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# === REQUIRED ===
# Get a free API key at https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# === LLM (optional — defaults shown) ===
MISTRAL_BASE_URL=https://api.mistral.ai/v1
# Free & capable models: mistral-small-latest, open-mistral-7b
LLM_MODEL=mistral-small-latest

# === CHUNKING (optional) ===
MAX_CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_RESULTS=5

# === UPLOAD (optional) ===
# Max file size in bytes (default: 50 MB)
MAX_UPLOAD_BYTES=52428800

# === SERVER (optional) ===
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Comma-separated allowed CORS origins (for local dev)
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === PATHS (override for Docker — set automatically by docker-compose) ===
UPLOAD_DIR=./uploads
CHROMA_PERSIST_DIR=./chroma_db

# === FRONTEND (for local dev only — Docker uses nginx proxy) ===
VITE_API_BASE_URL=/api
VITE_SWAGGER_URL=http://localhost:8000/docs
