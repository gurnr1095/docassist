# Get a free API key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter endpoint (no need to change)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model to use — any OpenRouter-compatible model ID
# Free options: meta-llama/llama-3.3-8b-instruct, mistralai/mistral-7b-instruct
LLM_MODEL=meta-llama/llama-3.3-8b-instruct

# ChromaDB storage path (relative to project root)
CHROMA_PERSIST_DIR=./chroma_db

# Chunking settings
MAX_CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Number of chunks to retrieve per query
TOP_K_RESULTS=5
